# .env.example — AI-mazing Analyst
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env (which is gitignored) and fill in real values, OR
# export the variables in your shell before running Streamlit:
#
#   export AMPLITUDE_API_KEY=your_key_here
#   export AMPLITUDE_SECRET_KEY=your_secret_here
#   streamlit run app.py
#
# For Streamlit Cloud: add these under App Settings → Secrets as TOML, e.g.:
#   AMPLITUDE_API_KEY     = "your_key_here"
#   AMPLITUDE_SECRET_KEY  = "your_secret_here"
#
# Find your API credentials in Amplitude:
#   Settings → Projects → [your project] → API Credentials
# ─────────────────────────────────────────────────────────────────────────────

# Required — Amplitude project API key (public identifier)
AMPLITUDE_API_KEY=your_amplitude_api_key_here

# Required — Amplitude project secret key (treat like a password)
AMPLITUDE_SECRET_KEY=your_amplitude_secret_key_here

# Optional — Amplitude app/project ID (used in status messages only).
# Leave blank to auto-detect from the API key's associated project.
AMPLITUDE_PROJECT_ID=

# Optional — set to "eu" if your Amplitude org is on the EU data centre.
# Leave blank (or "us") for the default US region.
AMPLITUDE_REGION=us
